<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#hasLegalBasis
:hasLegalBasis rdf:type owl:ObjectProperty ;
               rdfs:domain :DataProcessingActivity ;
               rdfs:range :LawfulBasis ;
               :source :Section24 ;
               rdfs:comment "Links a personal data processing activity to the lawful basis that justifies the collection, use, or disclosure of personal data." ;
               rdfs:isDefinedBy "Section24" ;
               rdfs:label "hasLegalBasis" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#subjectToPDPA
:subjectToPDPA rdf:type owl:ObjectProperty ;
               rdfs:domain :Entity ,
                           :PublicSectorEntity ;
               rdfs:range :PersonalDataProtectionAct ;
               rdfs:comment "Links an entity to the personal data protection act that applies to it." ;
               rdfs:label "subjectToPDPA" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/MandatoryExplicitFor
:MandatoryExplicitFor rdf:type owl:ObjectProperty ;
                      rdfs:domain :Consent ;
                      rdfs:range :Sensitive_Personal_Data ;
                      :source "Section26" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/actsAsDataController
:actsAsDataController rdf:type owl:ObjectProperty ;
                      rdfs:domain :PublicSectorEntity ;
                      rdfs:range :Data_Controller ;
                      :source :Section6 ;
                      rdfs:comment "Links an entity to the Data Controller role when the entity determines the purposes and means of collecting, using, or disclosing personal data." ;
                      rdfs:label "actsAsDataController" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/actsAsDataProcessor
:actsAsDataProcessor rdf:type owl:ObjectProperty ;
                     rdfs:domain :PublicSectorEntity ;
                     rdfs:range :Data_Processor ;
                     :source :Section6 ;
                     rdfs:comment "Links an entity to the Data Processor role when the entity processes personal data according to instructions from or on behalf of a Data Controller." ;
                     rdfs:label "actsAsDataProcessor" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/adopt
:adopt rdf:type owl:ObjectProperty ;
       rdfs:domain :Data_Controller ;
       rdfs:range :Personal_Data_Protection_Policy ;
       :source "Seciton29" ;
       rdfs:comment "Data Controller may adopt Data Protection Policy." .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/certifies
:certifies rdf:type owl:ObjectProperty ;
           rdfs:domain :PDPC ;
           rdfs:range :Personal_Data_Protection_Policy ;
           :source "Section29" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/collects
:collects rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :processData ;
          rdfs:domain :Data_Controller ;
          rdfs:range :Personal_Data ;
          :source "Section19" ;
          rdfs:comment "DataController collects PersonalData" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/discloses
:discloses rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :processData ;
           rdfs:domain :Data_Controller ;
           rdfs:range :Personal_Data ;
           :source "Section19" ;
           rdfs:comment "DataController discloses PersonalData" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/establish
:establish rdf:type owl:ObjectProperty ;
           rdfs:domain :Data_Controller ;
           rdfs:range :LawfulBasis ;
           :source "Section24" ;
           rdfs:comment "DataController must establish Lawful Basis" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/exercises
:exercises rdf:type owl:ObjectProperty ;
           rdfs:domain :Data_Subject ;
           rdfs:range :Data_Subject_Rights ;
           :source "Section30-36" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/governedBy
:governedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Cross-border_Transfer ;
            rdfs:range :Personal_Data_Protection_Policy ;
            :source "Section29" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/hasConsentRecord
:hasConsentRecord rdf:type owl:ObjectProperty ;
                  rdfs:domain :DataProcessingActivity ;
                  rdfs:range :Consent ;
                  rdfs:comment "Link a processing to the concrete consent the subject gave." ;
                  rdfs:label "hasConsentRecord" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/has_Chapter
:has_Chapter rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_part ;
             owl:inverseOf :is_part_of_Chapter ;
             rdfs:domain :LegalResourceSubdivision ;
             rdfs:range :Chapter ;
             rdfs:comment "indicates the legal resource has the Chapter" ;
             rdfs:label "hasChapter" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/has_Part
:has_Part rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :has_part ;
          owl:inverseOf :is_part_of_Part ;
          rdfs:domain :LegalResourceSubdivision ;
          rdfs:range :Part ;
          rdfs:comment "indicates the legal resource has the Part under some Chapters" ;
          rdfs:label "hasPart" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/has_Section
:has_Section rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_part ;
             owl:inverseOf :is_part_of_Section ;
             rdfs:domain :LegalResourceSubdivision ;
             rdfs:range :Section ;
             rdfs:comment "indicates the legal resource has the Section under Chapter or Part" ;
             rdfs:label "hasSection" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/has_part
:has_part rdf:type owl:ObjectProperty ;
          rdfs:label "hasPart" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/identifies
:identifies rdf:type owl:ObjectProperty ;
            rdfs:domain :Personal_Data ;
            rdfs:range :Data_Subject ;
            rdfs:comment "Personal Data identifies a Data Subject"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/is_part_of
:is_part_of rdf:type owl:ObjectProperty ;
            rdfs:label "isPartOf" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/is_part_of_Chapter
:is_part_of_Chapter rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :is_part_of ;
                    rdfs:domain :LegalResourceSubdivision ;
                    rdfs:range :Chapter ;
                    rdfs:comment "represents a legal resource subdivision to be part of a chapter" ;
                    rdfs:label "isPartOfChapter" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/is_part_of_Part
:is_part_of_Part rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :is_part_of ;
                 rdfs:domain :LegalResourceSubdivision ;
                 rdfs:range :Part ;
                 rdfs:comment "represents a legal resource subdivision to be part of a  Part under some Chapter" ;
                 rdfs:label "isPartOfPart" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/is_part_of_Section
:is_part_of_Section rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :is_part_of ;
                    rdfs:domain :LegalResourceSubdivision ;
                    rdfs:range :Section ;
                    rdfs:comment "represents a legal resource subdivision to be part of a Section under Part or Chapter" ;
                    rdfs:label "isPartOfSection" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/issuesRulesFor
:issuesRulesFor rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdfs:domain :PDPC ;
                rdfs:range :Cross-border_Transfer ;
                :source "Section 16" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/obtain
:obtain rdf:type owl:ObjectProperty ;
        rdfs:domain :Data_Controller ;
        rdfs:range :Consent ;
        :source "Section19" ;
        rdfs:comment "DataController obtains Consent" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/override
:override rdf:type owl:ObjectProperty ;
          rdfs:domain :LawfulBasis ;
          rdfs:range :Consent ;
          :source "Section24" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/processData
:processData rdf:type owl:ObjectProperty ;
             rdfs:domain :DataProcessingActivity ;
             rdfs:range :Personal_Data ;
             rdfs:comment "processes data item/category" ;
             rdfs:label "processData" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/processOnBehalfOf
:processOnBehalfOf rdf:type owl:ObjectProperty ;
                   rdfs:domain :Data_Processor ;
                   rdfs:range :Data_Controller ;
                   :source "Section6" ;
                   rdfs:comment "DataProcessor processes on behalf of DataController." .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/provide
:provide rdf:type owl:ObjectProperty ;
         rdfs:domain :Data_Controller ;
         rdfs:range :PrivacyNotice ;
         :source "Section23" ;
         rdfs:comment "DataController must provide Notice" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/provides
:provides rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :Data_Subject ;
          rdfs:range :Consent ;
          :source "Section19" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/receives
:receives rdf:type owl:ObjectProperty ;
          rdfs:domain :Data_Subject ;
          rdfs:range :PrivacyNotice ;
          :source "Section23" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/requiredFor
:requiredFor rdf:type owl:ObjectProperty ;
             rdfs:domain :Consent ;
             rdfs:range :Personal_Data ;
             :source "Section19" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/requiresConsent
:requiresConsent rdf:type owl:ObjectProperty ;
                 rdfs:domain :Sensitive_Personal_Data ;
                 rdfs:range :Consent ;
                 rdfs:label "requiresConsent" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/transferToForeignCountry
:transferToForeignCountry rdf:type owl:ObjectProperty ;
                          rdfs:domain :Data_Controller ;
                          rdfs:range :Cross-border_Transfer ;
                          :source "Section28" ;
                          rdfs:comment "Data Controller may transfer to foreign country via Cross border Transfer ." .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/uses
:uses rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf :processData ;
      rdfs:domain :Data_Controller ;
      rdfs:range :Personal_Data ;
      :source "Section19" ;
      rdfs:comment "DataController uses PersonalData" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/description
:description rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/source
:source rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#ExplicitConsentException
:ExplicitConsentException rdf:type owl:Class ;
                          rdfs:subClassOf :Rule ;
                          :source :Section26 ;
                          rdfs:comment "An exception under PDPA Section 26 where sensitive personal data may be collected without explicit consent." ;
                          rdfs:isDefinedBy "Section 26" ;
                          rdfs:label "ExplicitConsentException" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Accuracy
:Accuracy rdf:type owl:Class ;
          rdfs:subClassOf :Data_Activity ;
          :involves :Data_Controller ,
                    :Personal_Data ;
          rdfs:comment "Ensuring personal data remains accurate, complete, and not misleading." ;
          rdfs:isDefinedBy "Section 35" ;
          rdfs:label "Accuracy" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/BiometricData
:BiometricData rdf:type owl:Class ;
               rdfs:subClassOf :Sensitive_Personal_Data ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :requiresConsent ;
                                 owl:someValuesFrom :ExplicitConsent
                               ] ;
               :source :Section26 ;
               rdfs:comment "Biometric data is sensitive personal data under PDPA Section 26. It refers to personal data arising from techniques or technology related to the physical or behavioral characteristics of a person, which can be used to identify that person apart from others, such as facial recognition data, iris recognition data, or fingerprint recognition data."@en ;
               rdfs:isDefinedBy "Section 26" ;
               rdfs:label "BiometricData"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Chapter
:Chapter rdf:type owl:Class ;
         rdfs:subClassOf :LegalResourceSubdivision ;
         rdfs:comment "Chapter in PDPA Thailand" ;
         rdfs:isDefinedBy <https://pdpathailand.com/> ;
         rdfs:label "Chapter" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/CompetentOfficial
:CompetentOfficial rdf:type owl:Class ;
                   rdfs:subClassOf :Entity ;
                   :source :Section6 ;
                   rdfs:comment "Any person appointed by the Minister to perform acts under this Act." ;
                   rdfs:isDefinedBy "Section6" ;
                   rdfs:label "CompetentOfficial" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Consent
:Consent rdf:type owl:Class ;
         rdfs:subClassOf :Process ;
         :involves :Data_Subject ,
                   :Personal_Data ;
         rdfs:comment """Section 19

Personal data cannot be collected, used, or disclosed without consent, unless a lawful exception applies.

Consent must be:

Explicit (written or electronic).

Clearly separated from other matters.

Easy to understand, using plain language.

Consent must be freely given — services or contracts cannot be made conditional on unnecessary data collection.

Data subjects can withdraw consent at any time, and withdrawal must be as easy as giving consent.

Section 20

For minors, incompetents, or quasi-incompetents → consent must be obtained from parents, guardians, or curators.

Section 21

Data can only be used/disclosed for the purpose notified at the time of collection. If a new purpose arises, fresh consent is required."""@en ;
         rdfs:isDefinedBy "section19" ;
         rdfs:label "Consent" ;
         <http://www.w3.org/2004/02/skos/core#definition> "Based on the Personal Data Protection Act, B.E. 2562 (2019), \"consent\" is a fundamental concept for handling personal data, and several provisions outline what constitutes valid consent and the activities surrounding it." .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Consent_Activity
:Consent_Activity rdf:type owl:Class ;
                  rdfs:subClassOf :Process ;
                  rdfs:comment "The act by which a data subject gives or withdraws consent as prescribed in Section 19 of the PDPA." ;
                  rdfs:isDefinedBy "Section19 (Part 1, General Provisions, Chapter II)" ;
                  rdfs:label "ConsentActivity" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Controller_Obligation
:Controller_Obligation rdf:type owl:Class ;
                       rdfs:subClassOf :Obligation ;
                       :definition """A duty imposed by the Personal Data Protection Act on an actor.

“Section 37 The Data Controller shall have the following duties: (1) provide appropriate security measures… (4) notify the Office of any Personal Data breach…”""" ;
                       :involves :Data_Controller ;
                       rdfs:comment """Duties of Data Controllers:

- Implement appropriate security measures to prevent loss, unauthorized access, use, alteration, correction, or disclosure of Personal Data. [Section 37]

 - Prevent unlawful use or disclosure by recipients of Personal Data

-  Establish systems for erasure or destruction of Personal Data when retention ends, it's no longer necessary, or upon data subject's request/withdrawal of consent (with specific exceptions for retention) [Section 24 (1) or (4) , Section 26 (5) (a) or (b), Section 33 paragraph 5]

- Notify the Office of any Personal Data breach without undue delay (within 72 hours if feasible), unless unlikely to risk rights and freedoms. High-risk breaches must also be notified to data subjects

- Foreign Data Controllers (as defined in section 5 paragraph two) must designate a representative in Thailand [Section 38]

- Maintain records of processing activities, including collected data, purposes, retention, and security measures [Section 39]"""@en ;
                       rdfs:isDefinedBy "Section 37" ;
                       rdfs:label "ControllerObligations" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/CriminalRecords
:CriminalRecords rdf:type owl:Class ;
                 rdfs:subClassOf :Sensitive_Personal_Data ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :requiresConsent ;
                                   owl:someValuesFrom :ExplicitConsent
                                 ] ;
                 :source :Section26 ;
                 rdfs:comment "Criminal record data is a category of sensitive personal data under PDPA Section 26. Its collection is subject to strict legal conditions and generally requires explicit consent unless a legal exception applies."@en ;
                 rdfs:isDefinedBy "Section 26" ;
                 rdfs:label "CriminalRecords"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Cross-border_Transfer
:Cross-border_Transfer rdf:type owl:Class ;
                       rdfs:subClassOf :Disclosure ;
                       :involves :DataController ,
                                 :Personal_Data ,
                                 :Personal_Data_Protection_Policy ;
                       :source "Section 28, 29"@en ;
                       rdfs:comment """Cross-border Personal Data Transfer

Sending/Transferring to a foreign country or international organization.

General rule: Destination must have adequate protection standard
Exceptions (Section28): Legal compliance; data subject consent (informed of inadequacy); contract performance; inter-controller contract for data subject benefit; vital interests; substantial public interest
Certification route; Binding Corporate Rules certified by PDPC (Section29)

Section 28 In the event that the Data Controller sends or transfers the
Personal Data to a foreign country, the destination country or international organization that receives such Personal Data shall have adequate data protection standard, and shall be carried out in accordance with the rules for the protection of Personal Data as prescribed by the Committee in section 16(5), except in the following circumstances:
(1) where it is for compliance with the law;
(2) where the consent of the data subject has been obtained, provided that the
data subject has been informed of the inadequate Personal Data protection standards of the destination country or international organization;
(3) where it is necessary for the performance of a contract to which the data
subject is a party, or in order to take steps at the request of the data subject prior to entering into a contract;
(4) where it is for compliance with a contract between the Data Controller, and
other Persons or juristic persons for the interests of the data subject;
(5) where it is to prevent or suppress a danger to the life, body, or health of the
data subject or other Persons, when the data subject is incapable of giving the consent at such time;
(6) where it is necessary for carrying out the activities in relation to substantial
public interest.

In the event that there is a problem with regard to the adequacy of Personal Data
protection standards of the destination country or international organization, such problem shall be submitted to the Committee to decide. The decision made by the Committee may be reviewed when there is a new evidence convincing that the destination country or international organization that receives such Personal Data has developed adequate Personal Data protection standards.

Section 29 In the event that the Data Controller or the Data Processor who
is in the Kingdom of Thailand has put in place a Personal Data protection policy regarding the sending or transferring of Personal Data to another Data Controller or Data Processor who is in a foreign country, and is in the same affiliated business, or is in the same group of undertakings, in order to jointly operate the business or group of undertakings. If such Personal Data protection policy has been reviewed and certified by the Office, the sending or transferring of Personal Data to a foreign country, which is in accordance with such reviewed and certified Personal Data protection policy, can be carried out and shall be exempt from compliance with section 28.

The Personal Data protection policy, the nature of the same affiliated
undertaking or affiliated business in order to jointly operate the undertaking or business, and the rules and methods for the review and certification in paragraph one shall be as prescribed and announced by the Committee.
In the absent of a decision by the Committee in accordance with section 28, or
the Personal Data protection policy referred in paragraph one, the Data Controller or the Data Processor may send or transfer the Personal Data to a foreign country in exemption to compliance with section 28, if the Data Controller or the Data Processor provides suitable protection measures
which enable the enforcement of the data subject’s rights, including effective legal remedial measures according to the rules and methods as prescribed and announced by the Committee.""" ;
                       rdfs:label "CrossBorderTransfer" ;
                       rdfs:seeAlso """Section 28 In the event that the Data Controller sends or transfers the
Personal Data to a foreign country, the destination country or international organization that receives such Personal Data shall have adequate data protection standard, and shall be carried out in accordance with the rules for the protection of Personal Data as prescribed by the Committee in section 16(5), except in the following circumstances:
(1) where it is for compliance with the law;
(2) where the consent of the data subject has been obtained, provided that the
data subject has been informed of the inadequate Personal Data protection standards of the destination country or international organization;
(3) where it is necessary for the performance of a contract to which the data
subject is a party, or in order to take steps at the request of the data subject prior to entering into a contract;
(4) where it is for compliance with a contract between the Data Controller, and
other Persons or juristic persons for the interests of the data subject;
(5) where it is to prevent or suppress a danger to the life, body, or health of the
data subject or other Persons, when the data subject is incapable of giving the consent at such time;
(6) where it is necessary for carrying out the activities in relation to substantial
public interest.

In the event that there is a problem with regard to the adequacy of Personal Data
protection standards of the destination country or international organization, such problem shall be submitted to the Committee to decide. The decision made by the Committee may be reviewed when there is a new evidence convincing that the destination country or international organization that receives such Personal Data has developed adequate Personal Data protection standards.

Section 29 In the event that the Data Controller or the Data Processor who
is in the Kingdom of Thailand has put in place a Personal Data protection policy regarding the sending or transferring of Personal Data to another Data Controller or Data Processor who is in a foreign country, and is in the same affiliated business, or is in the same group of undertakings, in order to jointly operate the business or group of undertakings. If such Personal Data protection policy has been reviewed and certified by the Office, the sending or transferring of Personal Data to a foreign country, which is in accordance with such reviewed and certified Personal Data protection policy, can be carried out and shall be exempt from compliance with section 28.

The Personal Data protection policy, the nature of the same affiliated
undertaking or affiliated business in order to jointly operate the undertaking or business, and the rules and methods for the review and certification in paragraph one shall be as prescribed and announced by the Committee.
In the absent of a decision by the Committee in accordance with section 28, or
the Personal Data protection policy referred in paragraph one, the Data Controller or the Data Processor may send or transfer the Personal Data to a foreign country in exemption to compliance with section 28, if the Data Controller or the Data Processor provides suitable protection measures
which enable the enforcement of the data subject’s rights, including effective legal remedial measures according to the rules and methods as prescribed and announced by the Committee.""" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/CultData
:CultData rdf:type owl:Class ;
          rdfs:subClassOf :Sensitive_Personal_Data ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :requiresConsent ;
                            owl:someValuesFrom :ExplicitConsent
                          ] ;
          :source :Section26 ;
          rdfs:comment "Cult-related data is a category of sensitive personal data under PDPA Section 26. It generally requires explicit consent unless a legal exception applies."@en ;
          rdfs:isDefinedBy "Section 26" ;
          rdfs:label "CultData"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/DPO_Obligation
:DPO_Obligation rdf:type owl:Class ;
                rdfs:subClassOf :Obligation ;
                :definition "Section 42 The data protection officer shall have the following duties: (1) give advice… (4) keep confidentiality of Personal Data…" ;
                :involves :Data_Protection_Officer_DPO ;
                rdfs:comment """Advice & Guidance: Give advice to the Data Controller or Data Processor (and their employees or service-providers) on complying with the PDPA. thailand-personal-data-…

Monitoring & Investigation: Investigate how the Data Controller or Data Processor (and their employees or service-providers) collect, use, or disclose personal data to ensure PDPA compliance. thailand-personal-data-…

Coordination with the PDPC: Coordinate and cooperate with the Personal Data Protection Office whenever problems arise in personal-data processing under the PDPA. thailand-personal-data-…

Confidentiality: Maintain the confidentiality of any personal data accessed in the course of duty.""" ;
                rdfs:isDefinedBy "Chapter IV, Section 42" ,
                                 "Section 42" ;
                rdfs:label "DataProtectionOfficerObligations" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Data
:Data rdf:type owl:Class ;
      rdfs:subClassOf :Entity ;
      rdfs:comment "Any information in any form, including both personal and non-personal data." ;
      rdfs:label "Data" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/DataAccess
:DataAccess rdf:type owl:Class ;
            rdfs:subClassOf :Data_Activity ;
            :involves :Data_Controller ,
                      :Data_Subject ,
                      :Personal_Data ;
            rdfs:comment "The right to request and receive a copy of one’s personal data in a machine-readable format." ;
            rdfs:isDefinedBy "Section 30" ;
            rdfs:label "DataAccessActivity" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/DataCollectionActivity
:DataCollectionActivity rdf:type owl:Class ;
                        rdfs:subClassOf :DataProcessingActivity ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :hasLegalBasis ;
                                          owl:hasValue :LB_ContractPerformance
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :hasLegalBasis ;
                                          owl:hasValue :LB_HistoricalResearchStatistics
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :hasLegalBasis ;
                                          owl:hasValue :LB_LegalCompliance
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :hasLegalBasis ;
                                          owl:hasValue :LB_LegitimateInterests
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :hasLegalBasis ;
                                          owl:hasValue :LB_PublicTaskOfficialAuthority
                                        ] ;
                        :involves :Data_Controller ,
                                  :Personal_Data ;
                        rdfs:comment """This refers to the act of gathering or acquiring Personal Data.

The act of obtaining personal data from a data subject or a third party. Collection must be for a notified purpose and limited to what’s necessary.""" ;
                        rdfs:isDefinedBy "Section 22" ;
                        rdfs:label "DataCollectionActivity" ;
                        <http://www.w3.org/2004/02/skos/core#definition> """The document informing the data owner about the collection of personal data does not necessarily have to be the data owner's name. The company should consider the document informing the data owner about the collection of personal data in the data set in the initial process before collecting personal data.

 If the company wants to collect retrospective data for various works such as  the photos, positions and outstanding achievements,y can collect such data based on legitimate interests. In promoting the company, they should store permanently stored data such as lists of former employees. The company should retain personal data only as necessary and in accordance with the specified data retention period.""" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/DataObjectionActivity
:DataObjectionActivity rdf:type owl:Class ;
                       rdfs:subClassOf :Data_Activity ;
                       :involves :Data_Controller ,
                                 :Data_Subject ,
                                 :Personal_Data ;
                       rdfs:comment "The right to object to collection, use, or disclosure of personal data under certain circumstances." ;
                       rdfs:isDefinedBy "Section 32" ;
                       rdfs:label "DataObjectionActivity" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/DataProcessingActivity
:DataProcessingActivity rdf:type owl:Class ;
                        rdfs:subClassOf :Data_Activity ;
                        :involves :Data_Controller ,
                                  :Data_Processor ,
                                  :Personal_Data ;
                        rdfs:comment "Any operation on personal data, including collection, use, or disclosure." ;
                        rdfs:isDefinedBy "Section5" ;
                        rdfs:label "DataProcessingActivity" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/DataRecordkeepingActivity
:DataRecordkeepingActivity rdf:type owl:Class ;
                           rdfs:subClassOf :Data_Activity ;
                           :involves :Data_Controller ,
                                     :Personal_Data ;
                           rdfs:comment "Documenting all personal data processing activities, including categories of data, purposes, retention, and security measures." ;
                           rdfs:isDefinedBy "Section39" ;
                           rdfs:label "DataRecordkeepingActivity" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Data_Activity
:Data_Activity rdf:type owl:Class ;
               rdfs:subClassOf :Process ;
               :rendered "Personal Data Processing Activity" ;
               rdfs:comment "Generic class for any operation on personal data." ;
               rdfs:isDefinedBy "Chapter II (part II - IV)" ;
               rdfs:label "DataActivity" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Data_Controller
:Data_Controller rdf:type owl:Class ;
                 rdfs:subClassOf :Role ;
                 :definition "“A Person or a juristic person having the power and duties to make decisions regarding the collection, use, or disclosure of the Personal Data.”" ;
                 :source "Section 6, 19–29" ;
                 rdfs:comment """\"Data Controller\" refers to a Person or juristic person with the power and duties to make decisions regarding the collection, use, or disclosure of Personal Data.

Obligations:
Consent, notification, purpose limitation, data minimisation, security, records"""@en ;
                 rdfs:isDefinedBy "Section 6" ;
                 rdfs:label "DataController" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Data_Processor
:Data_Processor rdf:type owl:Class ;
                rdfs:subClassOf :Role ;
                :source "Section 6" ;
                rdfs:comment "\"Data Processor\" is a Person or juristic person who operates in relation to the collection, use, or disclosure of Personal Data pursuant to the orders given by or on behalf of a Data Controller, and is not the Data Controller themselves."@en ;
                rdfs:label "DataProcessor" ;
                <http://www.w3.org/2004/02/skos/core#definition> "Person/juristic person operating on Personal Data on behalf of a Data Controller" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Data_Protection_Officer_DPO
:Data_Protection_Officer_DPO rdf:type owl:Class ;
                             rdfs:subClassOf :Role ;
                             rdfs:comment """Duties of Data Protection Officer (DPO)
- Required for public authorities, organizations with large-scale regular monitoring of Personal Data, or those whose core activity involves processing sensitive Personal Data.
- Duties include: advising the Data Controller/Processor and employees on compliance, investigating performance, coordinating with the Office, and maintaining confidentiality.
- Data Controllers and Data Processors must support the DPO's work and must not dismiss them for performing duties under the Act.

[Section 41]"""@en ;
                             rdfs:isDefinedBy "Section 6" ;
                             rdfs:label "DataProtectionOfficer" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Data_Subject
:Data_Subject rdf:type owl:Class ;
              rdfs:subClassOf :Role ;
              :definition "The natural person to whom the Personal Data relates" ;
              rdfs:comment """An individual or entity to whom their personal data relates.

Special cases
Minor (< 10 yrs: parent consent; < 18 yrs: parental consent for non-autonomous acts), Incompetent (custodian), Quasi-incompetent (curator)"""@en ;
              rdfs:isDefinedBy "Section 6, 20" ;
              rdfs:label "DataSubject" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Data_Subject_Rights
:Data_Subject_Rights rdf:type owl:Class ;
                     rdfs:subClassOf :Right ;
                     :involves :Data_Subject ;
                     :source "Section 19, 30–36, 73" ;
                     rdfs:comment """PDPA provides several rights to the data subjects.

Rights: Consent withdrawal, access, correction, erasure, restriction, data portability, objection
Notification; Data Controller must inform of these rights in the Notice (§23(6))"""@en ;
                     rdfs:label "DataSubjectRights" ;
                     rdfs:seeAlso """Section 29 In the event that the Data Controller or the Data Processor who
is in the Kingdom of Thailand has put in place a Personal Data protection policy regarding the
sending or transferring of Personal Data to another Data Controller or Data Processor who is in
a foreign country, and is in the same affiliated business, or is in the same group of undertakings,
in order to jointly operate the business or group of undertakings. If such Personal Data protection
policy has been reviewed and certified by the Office, the sending or transferring of Personal Data to a foreign country, which is in accordance with such reviewed and certified Personal Data
protection policy, can be carried out and shall be exempt from compliance with section 28.
The Personal Data protection policy, the nature of the same affiliated
undertaking or affiliated business in order to jointly operate the undertaking or business, and the
rules and methods for the review and certification in paragraph one shall be as prescribed and
announced by the Committee.
In the absent of a decision by the Committee in accordance with section 28, or
the Personal Data protection policy referred in paragraph one, the Data Controller or the Data
Processor may send or transfer the Personal Data to a foreign country in exemption to compliance
with section 28, if the Data Controller or the Data Processor provides suitable protection measures
which enable the enforcement of the data subject’s rights, including effective legal remedial
measures according to the rules and methods as prescribed and announced by the Committee."""@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/DisabilityData
:DisabilityData rdf:type owl:Class ;
                rdfs:subClassOf :Sensitive_Personal_Data ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :requiresConsent ;
                                  owl:someValuesFrom :ExplicitConsent
                                ] ;
                :source :Section26 ;
                rdfs:comment "Disability data is a category of sensitive personal data under PDPA Section 26. It generally requires explicit consent unless a legal exception applies."@en ;
                rdfs:isDefinedBy "Section 26" ;
                rdfs:label "DisabilityData"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Disclosure
:Disclosure rdf:type owl:Class ;
            rdfs:subClassOf :DataProcessingActivity ;
            :involves :Data_Controller ,
                      :Personal_Data ;
            rdfs:comment "Sharing personal data with another domestic party or transferring it to a foreign country or international organisation." ;
            rdfs:isDefinedBy "Section 27, Section 28" ;
            rdfs:label "DisclosureofPersonalData" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Entity
:Entity rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
        :source :Section6 ;
        :eli:title_alternative "Actor" ;
        rdfs:comment """Individual or Entity in the PDPA

Section 6 In this Act,
“Personal Data” means any information relating to a Person, which enables
the identification of such Person, whether directly or indirectly, but not including the
information of the deceased Persons in particular;
“Data Controller” means a Person or a juristic person having the power and
duties to make decisions regarding the collection, use, or disclosure of the Personal Data;
“Data Processor” means a Person or a juristic person who operates in relation
to the collection, use, or disclosure of the Personal Data pursuant to the orders given by or on
behalf of a Data Controller, whereby such Person or juristic person is not the Data Controller;
“Person” means a natural person;
“Committee” means the Personal Data Protection Committee;
“Competent Official” means any person appointed by the Minister to perform
acts under this Act;
“Office” means the Office of the Personal Data Protection Committee;
“Secretary-General” means the Secretary-General of the Personal Data
Protection Committee;
“Minister” means the Minister who is in charge under this Act.
Section 7 The Minister of Digital Economy and Society shall be in
charge under this Act, and shall have the power to appoint the Competent Official to perform
acts under this Act."""@en ;
        rdfs:isDefinedBy "Section 6" ;
        rdfs:label "Entity" ;
        rdfs:seeAlso "Individuals" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Erase_Data
:Erase_Data rdf:type owl:Class ;
            rdfs:subClassOf :Data_Activity ;
            :involves :Data_Controller ,
                      :Personal_Data ;
            rdfs:comment "Erasing, destroying or anonymising personal data when no longer needed or upon request." ;
            rdfs:isDefinedBy "Section 33" ;
            rdfs:label "RetentionandErasure" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/EthnicOrigin
:EthnicOrigin rdf:type owl:Class ;
              rdfs:subClassOf :Sensitive_Personal_Data ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :requiresConsent ;
                                owl:someValuesFrom :ExplicitConsent
                              ] ;
              :source :Section26 ;
              rdfs:comment "Ethnic origin data is a category of sensitive personal data under PDPA Section 26. It generally requires explicit consent unless a legal exception applies."@en ;
              rdfs:isDefinedBy "Section 26" ;
              rdfs:label "EthnicOrigin"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/ExplicitConsent
:ExplicitConsent rdf:type owl:Class ;
                 rdfs:subClassOf :Consent ;
                 :source "Section26" ;
                 rdfs:comment "Expressly indicated consent required for sensitive personal data under PDPA Section 26, unless a legal exception applies." ;
                 rdfs:isDefinedBy "Section26" ;
                 rdfs:label "ExplicitConsent" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/GeneticData
:GeneticData rdf:type owl:Class ;
             rdfs:subClassOf :Sensitive_Personal_Data ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :requiresConsent ;
                               owl:someValuesFrom :ExplicitConsent
                             ] ;
             :source :Section26 ;
             rdfs:comment "Genetic data is a category of sensitive personal data under PDPA Section 26. It generally requires explicit consent unless a legal exception applies."@en ;
             rdfs:isDefinedBy "Section 26" ;
             rdfs:label "GeneticData"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/GovernmentAgency
:GovernmentAgency rdf:type owl:Class ;
                  rdfs:subClassOf :PublicSectorEntity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :subjectToPDPA ;
                                    owl:someValuesFrom :PersonalDataProtectionAct
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :actsAsDataController ;
                                    owl:someValuesFrom :Data_Controller
                                  ] ;
                  :example """Use instances only if there have specific classes
MinistryOfPublicHealth instanceOf GovernmentAgency
StateRailwayOfThailand instanceOf StateEnterprise""" ;
                  rdfs:comment "A government agency or public authority that may be subject to the PDPA when collecting, using, or disclosing personal data."@en ;
                  rdfs:label "GovernmentAgency" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/HealthData
:HealthData rdf:type owl:Class ;
            rdfs:subClassOf :Sensitive_Personal_Data ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :requiresConsent ;
                              owl:someValuesFrom :ExplicitConsent
                            ] ;
            :source :Section26 ;
            rdfs:comment "Health data is a category of sensitive personal data under PDPA Section 26. The collection, use, or disclosure of health data is subject to stricter conditions and generally requires explicit consent unless a legal exception applies."@en ;
            rdfs:isDefinedBy "Section 26" ;
            rdfs:label "HealthData"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Insensitive_Personal_Data
:Insensitive_Personal_Data rdf:type owl:Class ;
                           rdfs:subClassOf :Personal_Data ;
                           rdfs:comment "Definition: \"Personal Data\" means any information relating to a Person, which enables the identification of such Person, whether directly or indirectly, but not including the information of the deceased Persons in particular. This serves as the broad, overarching definition for what constitutes personal data under the Act"@en ;
                           rdfs:label "GeneralPersonalData" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/LawfulBasis
:LawfulBasis rdf:type owl:Class ;
             rdfs:subClassOf :Rule ;
             :definition """(1) Historical/statistical purpose; (2) Vital interests; (3) Contract performance; (4) Public task; (5) Legitimate interests; (6) Legal compliance

Explicit consent required for Sensitive Personal Data (Section 26) unless specific exception applies""" ;
             :source :Section24 ;
             rdfs:comment """(1) Historical/statistical purpose; (2) Vital interests; (3) Contract performance; (4) Public task; (5) Legitimate interests; (6) Legal compliance

Explicit consent required for Sensitive Personal Data (Section 26) unless specific exception applies"""@en ;
             rdfs:label "LawfulBasis" ;
             rdfs:seeAlso """Section 24 The Data Controller shall not collect Personal Data without the
consent of the data subject, unless:
(1) it is for the achievement of the purpose relating to the preparation of the
historical documents or the archives for public interest, or for the purpose relating to research or
statistics, in which the suitable measures to safeguard the data subject's rights and freedoms are
put in place and in accordance with the notification as prescribed by the Committee;
(2) it is for preventing or suppressing a danger to a Person’s life, body or health;
(3) it is necessary for the performance of a contract to which the data subject is
a party, or in order to take steps at the request of the data subject prior to entering into a contract;
(4) it is necessary for the performance of a task carried out in the public interest
by the Data Controller, or it is necessary for the exercising of official authority vested in the Data
Controller;
(5) it is necessary for legitimate interests of the Data Controller or any other
Persons or juristic persons other than the Data Controller, except where such interests are overridden by the fundamental rights of the data subject of his or her Personal Data;
(6) it is necessary for compliance with a law to which the Data Controller is
subjected.

Section 26 Any collection of Personal Data pertaining to racial, ethnic
origin, political opinions, cult, religious or philosophical beliefs, sexual behavior, criminal
records, health data, disability, trade union information, genetic data, biometric data, or of any
data which may affect the data subject in the same manner, as prescribed by the
Committee, is prohibited, without the explicit consent from the data subject, except where:
it is to prevent or suppress a danger to life, body or health of the Person,
wh e r e the data subject is incapable of giving consent by whatever reason;
it is carried out in the course of legitimate activities with appropriate safeguards
by the foundations, associations or any other not-for-profit bodies with a political, religious,
philosophical, or trade union purposes for their members, former members of the bodies, or
persons having regular contact with such foundations, associations or not-for-profit bodies in connection with their purposes, without disclosing the Personal Data outside of such
foundations, associations or not-for-profit bodies;
(1) it is information that is disclosed to the public with the explicit consent
of the data subject;
(2) it is necessary for the establishment, compliance, exercise or defense of
legal claims;
(3) it is necessary for compliance with a law to achieve the purposes with
respect to:
(a) preventive medicine or occupational medicine, the assessment of
working capacity of the employee, medical diagnosis, the provision of health or social care,
medical treatment, the management of health or social care systems and services. In the event
that it is not for compliance with the law, and such Personal Data is under the responsibility of
the occupational or profession practitioner or person having the duty to keep such Personal Data
as confidential under the law, it must be for compliance with the contract between the data subject
and the medical practitioner;
(b) public interest in public health, such as protecting against cross-border
dangerous contagious disease or epidemics which may be contagious or pestilent, or ensuring
standards or quality of medicines, medicinal products or medical devices, on the basis that there
is a provision of suitable and specific measures to safeguard the rights and freedom of the data
subject, in particular maintaining the confidentiality of Personal Data in accordance with the
duties or professional ethics;
(c) employment protection, social security, national health security, social
health welfare of the entitled person by law, the road accident victims protection, or social
protection in which the collection of Personal Data is necessary for exercising the rights or
carrying out the obligations of the Data Controller or the data subject, by providing the suitable
measures to protect the fundamental rights and interest of the data subject;
(d) it is for the scientific, historical, or statistic research purposes, or other
public interests which must be carried out only to the extent necessary to achieve such purposes,
and the suitable measures have been provided to protect the fundamental rights and interest of
the data subject as prescribed by the Committee;
(e) the substantial public interest, by providing the suitable measures to
protect the fundamental rights and interest of the data subject.
The biometric data in paragraph one shall mean the Personal Data arising from
the use of technics or technology related to the physical or behavioral dominance of Person,
which can be used to identify such Person apart from other Persons, such as the facial recognition
data, iris recognition data or fingerprint recognition data.
In the case of the collection of the Personal Data relating to criminal record, such
collection shall be carried out under the control of authorized official authority under the law, or
the data protection measure has been implemented according to rules prescribed by the
Committee."""@en .


