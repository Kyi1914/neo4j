      rdfs:subClassOf :Person ;
      :full_name "Personal Data Protection Comittee"@en ;
      :source :Section16 ,
              :Section8 ;
      :eli:title "Personal Data Protection Comittee"@en ;
      rdfs:comment """The Personal Data Protection Comittee

Composition
Chairperson + Vice-Chairperson + 5 ex-officio + 9 honorary directors

Key powers
Issue notifications/rules, certify BCRs, decide adequacy disputes, oversee enforcement"""@en ;
      rdfs:isDefinedBy "Section 8, 16"@en ;
