#    Individuals
#################################################################

###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#EmploymentSocialProtection
:EmploymentSocialProtection rdf:type owl:NamedIndividual .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#LB_ContractPerformance
:LB_ContractPerformance rdf:type owl:NamedIndividual ,
                                 :LawfulBasis ;
                        :source :Section24 ;
                        rdfs:comment "Personal data may be collected without consent when necessary for the performance of a contract with the data subject or to take steps at the data subject's request before entering into a contract." ;
                        rdfs:isDefinedBy "Section 24(3)" ;
                        rdfs:label "ContractPerformance" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#LB_HistoricalResearchStatistics
:LB_HistoricalResearchStatistics rdf:type owl:NamedIndividual ,
                                          :LawfulBasis ;
                                 :source :Section24 ;
                                 rdfs:comment "Personal data may be collected without consent for historical documents, archives for public interest, research, or statistics, where suitable safeguards are provided." ;
                                 rdfs:isDefinedBy "Section 24(1)" ;
                                 rdfs:label "HistoricalResearchStatistics" ;
                                 rdfs:seeAlso "Historical, Research, or Statistics Purpose" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#LB_LegalCompliance
:LB_LegalCompliance rdf:type owl:NamedIndividual ,
                             :LawfulBasis ;
                    :source :Section24 ;
                    rdfs:comment "Personal data may be collected without consent when necessary for compliance with a law to which the Data Controller is subject." ;
                    rdfs:isDefinedBy "Section 24(6)" ;
                    rdfs:label "LegalCompliance" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#LB_LegitimateInterests
:LB_LegitimateInterests rdf:type owl:NamedIndividual ,
                                 :LawfulBasis ;
                        :source :Section24 ;
                        rdfs:comment "Personal data may be collected without consent when necessary for legitimate interests of the Data Controller or another person or juristic person, unless overridden by the fundamental rights of the data subject." ;
                        rdfs:isDefinedBy "Section 24(5)" ;
                        rdfs:label "LegitimateInterests" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#LB_PublicTaskOfficialAuthority
:LB_PublicTaskOfficialAuthority rdf:type owl:NamedIndividual ,
                                         :LawfulBasis ;
                                :source :Section24 ;
                                rdfs:comment "Personal data may be collected without consent when necessary for a task carried out in the public interest by the Data Controller or for exercising official authority vested in the Data Controller." ;
                                rdfs:isDefinedBy "Section 24(4)" ;
                                rdfs:label "PublicTaskOfficialAuthority" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#LB_VitalInterests
:LB_VitalInterests rdf:type owl:NamedIndividual ,
                            :LawfulBasis ;
                   :source :Section24 ;
                   rdfs:comment "Personal data may be collected without consent to prevent or suppress danger to a person's life, body, or health." ;
                   rdfs:isDefinedBy "Section 24(2)" ;
                   rdfs:label "VitalInterests" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#LegalClaims
:LegalClaims rdf:type owl:NamedIndividual .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#ManifestlyPublicByConsent
:ManifestlyPublicByConsent rdf:type owl:NamedIndividual .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#NonProfitLegitimateActivities
:NonProfitLegitimateActivities rdf:type owl:NamedIndividual .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#PreventiveMedicineHealthCare
:PreventiveMedicineHealthCare rdf:type owl:NamedIndividual .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#PublicHealth
:PublicHealth rdf:type owl:NamedIndividual .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33#ResearchStatisticsPublicInterest
:ResearchStatisticsPublicInterest rdf:type owl:NamedIndividual .


