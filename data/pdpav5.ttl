###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Sensitive_Personal_Data
:Sensitive_Personal_Data rdf:type owl:Class ;
                         rdfs:subClassOf :Personal_Data ;
                         :definition "Special category data requiring explicit consent"@en ;
                         :involves :BiometricData ,
                                   :CriminalRecords ,
                                   :CultData ,
                                   :Data_Subject ,
                                   :DisabilityData ,
                                   :EthnicOrigin ,
                                   :GeneticData ,
                                   :HealthData ,
                                   :PoliticalOpinions ,
                                   :RacialData ,
                                   :ReligiousOrPhilosophicalBeliefs ,
                                   :SexualBehavior ,
                                   :TradeUnionInformation ;
                         :source :Section26 ;
                         rdfs:comment """Sensitive Personal Data (requiring explicit consent and subject to stricter prohibitions)
The collection of this specific kind of personal data is generally prohibited without explicit consent from the data subject, except under certain specified circumstances
This category includes data pertaining to:
        ▪ Racial or ethnic origin
        ▪ Political opinions
        ▪ Cult, religious or philosophical beliefs
        ▪ Sexual behavior
        ▪ Criminal records
        ▪ Health data
        ▪ Disability
        ▪ Trade union information
        ▪ Genetic data
        ▪ Biometric data"""@en ;
                         rdfs:isDefinedBy :Section26 ;
                         rdfs:label "SensitivePersonalData" ;
                         rdfs:seeAlso "PDPA s.26 categories require explicit consent unless an exception applies." .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/SexualBehavior
:SexualBehavior rdf:type owl:Class ;
                rdfs:subClassOf :Sensitive_Personal_Data ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :requiresConsent ;
                                  owl:someValuesFrom :ExplicitConsent
                                ] ;
                :source :Section26 ;
                rdfs:comment "Sexual behavior data is a category of sensitive personal data under PDPA Section 26. It generally requires explicit consent unless a legal exception applies."@en ;
                rdfs:isDefinedBy "Section 26" ;
                rdfs:label "SexualBehavior"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Share_Personal_Data_with_Third_Party
:Share_Personal_Data_with_Third_Party rdf:type owl:Class ;
                                      rdfs:subClassOf :Disclosure ;
                                      rdfs:label "Share with third party or another domestic party" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/StateEnterprise
:StateEnterprise rdf:type owl:Class ;
                 rdfs:subClassOf :PublicSectorEntity ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :subjectToPDPA ;
                                   owl:someValuesFrom :PersonalDataProtectionAct
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :actsAsDataController ;
                                   owl:someValuesFrom :Data_Controller
                                 ] ;
                 :example """Use instances only if there have specific classes
MinistryOfPublicHealth instanceOf GovernmentAgency
StateRailwayOfThailand instanceOf StateEnterprise""" ;
                 rdfs:comment "A state-owned or state-controlled enterprise that may be subject to the PDPA when collecting, using, or disclosing personal data."@en ;
                 rdfs:label "StateEnterprise" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/TradeUnionInformation
:TradeUnionInformation rdf:type owl:Class ;
                       rdfs:subClassOf :Sensitive_Personal_Data ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :requiresConsent ;
                                         owl:someValuesFrom :ExplicitConsent
                                       ] ;
                       :source :Section26 ;
                       rdfs:comment "Trade union information is a category of sensitive personal data under PDPA Section 26. It generally requires explicit consent unless a legal exception applies."@en ;
                       rdfs:isDefinedBy "Section 26" ;
                       rdfs:label "TradeUnionInformation"@en .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Use_Data
:Use_Data rdf:type owl:Class ;
          rdfs:subClassOf :DataProcessingActivity ;
          :involves :Data_Controller ,
                    :Personal_Data ;
          rdfs:comment "Any operation whereby the controller applies, handles, or otherwise utilises personal data for the purposes notified." ;
          rdfs:isDefinedBy "Section 27" ;
          rdfs:label "DataUseActivity" .


###  http://www.semanticweb.org/kyith/ontologies/2025/6/untitled-ontology-33/Withdrawing_Given_Consent
:Withdrawing_Given_Consent rdf:type owl:Class ;
                           rdfs:subClassOf :Data_Subject_Rights ;
                           :involves :Consent ,
                                     :Data_Subject ;
                           rdfs:label "ConsentWithdrawl" ,
                                      "The act by which a data subject withdraws previously given consent (Section 19)." .


